# ============================================================================
# SHUFFLE SOAR CONFIGURATION
# ============================================================================
SHUFFLE_URL=http://localhost:3001
SHUFFLE_API_KEY=your_shuffle_api_key_here

# Workflow IDs (set after importing workflows)
SHUFFLE_INCIDENT_RESPONSE_WORKFLOW_ID=
SHUFFLE_THREAT_HUNTING_WORKFLOW_ID=
SHUFFLE_ENDPOINT_ISOLATION_WORKFLOW_ID=
SHUFFLE_MISP_ENRICHMENT_WORKFLOW_ID=
SHUFFLE_TICKETING_WORKFLOW_ID=

# ============================================================================
# WAZUH CONFIGURATION
# ============================================================================
WAZUH_URL=https://localhost
WAZUH_USER=wazuh-wui
WAZUH_PASS=your_wazuh_password

# ============================================================================
# MISP THREAT INTELLIGENCE
# ============================================================================
MISP_URL=http://localhost
MISP_KEY=your_misp_api_key

# ============================================================================
# CROWDSTRIKE FALCON
# ============================================================================
CROWDSTRIKE_CLIENT_ID=your_client_id
CROWDSTRIKE_CLIENT_SECRET=your_client_secret
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# ============================================================================
# SPLUNK SIEM
# ============================================================================
SPLUNK_URL=https://localhost:8089
SPLUNK_TOKEN=your_hec_token
SPLUNK_INDEX=main

# ============================================================================
# GOOGLE CLOUD / VERTEX AI
# ============================================================================
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT=your-vertex-endpoint-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@company.com
SMTP_PASS=your_email_password
SOC_EMAIL=soc@company.com

# ============================================================================
# TICKETING SYSTEM (Optional)
# ============================================================================
TICKETING_SYSTEM=servicenow
TICKETING_URL=https://yourinstance.service-now.com
TICKETING_USER=api_user
TICKETING_PASS=api_password
